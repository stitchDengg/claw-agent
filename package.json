{
  "name": "claw-agent",
  "version": "1.0.0",
  "private": true,
  "description": "Claw Agent - AI 智能助手 (pnpm monorepo)",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @claw-agent/web dev",
    "dev:server": "pnpm --filter @claw-agent/server dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @claw-agent/web build",
    "build:server": "pnpm --filter @claw-agent/server build",
    "start": "pnpm -r --parallel start",
    "start:web": "pnpm --filter @claw-agent/web start",
    "start:server": "pnpm --filter @claw-agent/server start",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
